{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cd menu_management && flutter analyze)",
      "Bash(cd menu_management && dart run build_runner build *)",
      "Bash(cd menu_management && flutter test *)",
      "Bash(flutter devices)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE\"; case \"$FILE\" in *.dart) cd menu_management && dart format --line-length 150 \"$FILE\" ;; esac"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_FILE\"; case \"$FILE\" in *.dart) cd menu_management && dart format --line-length 150 \"$FILE\" ;; esac"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  }
}
